# Firebase Web SDK config.
# Get these values from: Firebase Console > Project Settings > General > Your apps > Web app
#
# These are NOT secret keys (Firebase web config is meant to be public —
# access control happens via Firestore/Storage Security Rules instead).
# That said, keep this as .env.local (gitignored) and set the same values
# in Vercel's Environment Variables UI for production.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Site-wide passphrase gate = GATE 1 (see docs/spec-v2.9-diff-2026-06-26.md §2).
# Anyone who knows this string can unlock the whole site for their browser.
SITE_PASSPHRASE=

# Private Experience passphrase = GATE 2 (see docs/spec-v2.9-diff-2026-06-26.md §2).
# Separate from SITE_PASSPHRASE. Required to view message text / voice
# playback inside the chapter-6 "MIKA Private Experience" (auto-play /
# garden explore / name list). Not yet wired to a page — see
# src/lib/privateExperienceAuth.ts for the verification helper that's
# ready for when that page gets built.
PRIVATE_EXPERIENCE_PASSPHRASE=

# Niya's personal preview key for the top-page evolution display
# (spec v2.9 §1.11.1). Accessed via ?preview=<this value> on the top page.
# Separate from both passphrases above — do not merge any of the three.
NEXT_PUBLIC_PREVIEW_KEY=
