rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /voices/{fileName} {
      // Read: open to everyone (same caveat as firestore.rules — real
      // protection is the UI-layer GATE 2, see docs/firebase-security-rules-draft.md).
      allow read: if true;

      // Create only. Reject anything that isn't a reasonably-sized webm
      // clip (60s of audio/webm comfortably fits under 5MB).
      allow create: if request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType == 'audio/webm';
      allow update, delete: if false;
    }
  }
}
